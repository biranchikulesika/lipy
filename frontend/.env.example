# =========================================================================
# LiPy Frontend Environment Configuration
# =========================================================================

# 1. FastAPI OCR Backend API
# The endpoint of the FastAPI backend service for Odia Handwriting Recognition.
# In production, this should point to your Azure deployment.
# Example: https://your-backend-app-name.up.railway.app
NEXT_PUBLIC_API_URL="http://localhost:8000"

# 2. Supabase Configuration Keys
# Used to authenticate administrators, sync user sessions, and link social accounts.
# You can obtain these from your Supabase Dashboard under Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-public-key"

# 3. Supabase Service Role Key (Server-Only Bypass Key)
# [OPTIONAL] Used only in trusted contexts (e.g. server cron jobs, bypassing Row Level Security).
# WARNING: NEVER prefix this with NEXT_PUBLIC_ as it must remain secret.
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-secret-key"
