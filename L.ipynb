    "    BatchNormalization(),                 # NEW\n",
    "    Dropout(0.4),                         # Increased from 0.3\n",
    "    \n",
    "    # Output\n",
    "    Dense(num_classes, activation='softmax')\n",
    "])\n",
    "\n",
    "model.compile(\n",
    "    optimizer='adam',\n",
    "    loss='categorical_crossentropy',\n",
    "    metrics=['accuracy']\n",
    ")\n",
