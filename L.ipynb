   "source": [
    "import numpy as np\n",
    "\n",
    "# ========== FUNCTION 1: ENSEMBLE PREDICTION ==========\n",
    "def ensemble_predict(model, image, datagen, n_augmentations=7):\n",
    "    \"\"\"\n",
    "    Predict by averaging predictions from original + augmented versions\n",
    "    \"\"\"\n",
    "    predictions = []\n",
    "    \n",
    "    # Original prediction\n",
    "    original_pred = model.predict(image.reshape(1, 64, 64, 1), verbose=0)[0]\n",
    "    predictions.append(original_pred)\n",
    "    \n",
    "    # Augmented predictions\n",
    "    for i in range(n_augmentations):\n",
    "        aug_batch = next(datagen.flow(\n",
    "            image.reshape(1, 64, 64, 1), \n",
    "            batch_size=1, \n",
    "            shuffle=False\n",
    "        ))\n",
    "        aug_pred = model.predict(aug_batch, verbose=0)[0]\n",
    "        predictions.append(aug_pred)\n",
    "    \n",
    "    # Average all predictions\n",
    "    ensemble_pred = np.mean(predictions, axis=0)\n",
    "    confidence = np.max(ensemble_pred)\n",
    "    predicted_class_idx = np.argmax(ensemble_pred)\n",
    "    \n",
    "    return ensemble_pred, confidence, predicted_class_idx\n",
    "\n",
    "\n",
    "# ========== FUNCTION 2: TEMPERATURE SCALING ==========\n",
    "def apply_temperature_scaling(probs, temperature=2.0):\n",
    "    \"\"\"\n",
    "    Scale down overconfident predictions\n",
    "    Higher temperature = softer predictions\n",
    "    \"\"\"\n",
    "    # Divide by temperature and renormalize\n",
    "    scaled_probs = probs ** (1.0 / temperature)\n",
    "    scaled_probs = scaled_probs / scaled_probs.sum()\n",
    "    return scaled_probs\n",
    "\n",
    "\n",
    "# ========== FUNCTION 3: CONFIDENT PREDICTION ==========\n",
    "def predict_with_confidence_threshold(model, image, datagen, \n",
    "                                     confidence_threshold=0.5, \n",
    "                                     temperature=2.0,\n",
    "                                     use_ensemble=True):\n",
    "    \"\"\"\n",
    "    Complete prediction function with all improvements\n",
    "    \"\"\"\n",
    "    if use_ensemble:\n",
    "        # Use ensemble prediction\n",
    "        ensemble_probs, confidence, pred_class_idx = ensemble_predict(\n",
    "            model, image, datagen, n_augmentations=7\n",
    "        )\n",
    "    else:\n",
    "        # Single prediction\n",
    "        probs = model.predict(image.reshape(1, 64, 64, 1), verbose=0)[0]\n",
    "        confidence = np.max(probs)\n",
    "        pred_class_idx = np.argmax(probs)\n",
    "        ensemble_probs = probs\n",
    "    \n",
    "    # Apply temperature scaling\n",
    "    ensemble_probs = apply_temperature_scaling(ensemble_probs, temperature=temperature)\n",
    "    confidence = np.max(ensemble_probs)\n",
    "    \n",
    "    # Check if meets confidence threshold\n",
    "    if confidence < confidence_threshold:\n",
    "        return None, confidence, \"UNCERTAIN\"\n",
    "    \n",
    "    return ensemble_probs, confidence, pred_class_idx\n",
    "\n",
    "\n",
    "print(\"вң… All prediction functions loaded!\")"
   ]
  },
