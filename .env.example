# -----------------------------------------------------------------------------
# Hugging Face
# -----------------------------------------------------------------------------

# Dataset repository used for training.
HF_DATASET_REPO_ID=biranchikulesika/lipy

# Dataset folder inside the Hugging Face dataset repository.
HF_DATASET_FOLDER=complete_dataset

# Model repository used by the backend.
HF_MODEL_REPO_ID=biranchikulesika/lipy

# Required only for:
# - Private Hugging Face repositories
# - Uploading datasets or models
#
# Leave empty for public read-only access.
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxx


# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

# Used by scripts/dataset/download_supabase.py

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required only for administrative operations.
# Never expose this key in frontend deployments.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key